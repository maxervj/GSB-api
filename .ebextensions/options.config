option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 8080
    # Variables sensibles à définir dans la console AWS EB (Environnement > Configuration > Logiciel) :
    # MONGODB_URI: <uri Atlas en production>
    # JWT_SECRET: <secret fort aléatoire>
    # JWT_EXPIRES_IN: 4h
    # CORS_ORIGIN: <url du frontend en production>
  aws:elasticbeanstalk:container:nodejs:
    ProxyServer: nginx
